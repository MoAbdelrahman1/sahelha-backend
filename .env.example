# Copy to .env for local dev. In Render, set these under the service's
# Environment tab instead of committing a .env file.

# --- Auth ---
# Any long random string in prod; the sample value is fine for local dev only.
SECRET_KEY=sahelha-dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- AI (Groq) ---
GROQ_API_KEY=
# Optional, defaults to llama-3.1-8b-instant. Use llama-3.3-70b-versatile
# for higher-quality Arabic comprehension at the cost of latency.
GROQ_MODEL=llama-3.1-8b-instant

# --- Push notifications (reminders) ---
# Firebase Cloud Messaging legacy server key. Reminders still get marked
# sent on schedule without this, the push just gets skipped.
FCM_SERVER_KEY=
REMINDER_CHECK_INTERVAL_SECONDS=1800

# --- CORS ---
# Comma-separated list of frontend origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Storage ---
UPLOAD_DIR=uploads
# Path to the SQLite file. Point this at a persistent-disk mount in prod.
DB_PATH=sahelha.db
